rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: Relaxed rules to allow game opponents to update ratings/stats
    // Ideally use Cloud Functions for rating updates, but allowed for now.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; 
    }
    
    match /leaderboard/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /game_scores/{scoreId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /games/{gameId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == resource.data.player1.uid || request.auth.uid == resource.data.player2.uid);
    }

    match /matchmaking/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /badges/{badgeId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
